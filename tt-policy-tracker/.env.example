# API Keys
OPENSTATES_API_KEY=your-openstates-api-key
CONGRESS_API_KEY=your-congress-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
POSTMARK_TOKEN=your-postmark-server-token

# Database — Railway sets this automatically when you add a Postgres plugin
# Accepts postgresql://, postgres://, or postgresql+asyncpg:// — all are auto-normalized
DATABASE_URL=postgresql://tracker:tracker@localhost:5432/policy_tracker

# S3 (optional for Phase 0 — local storage used as fallback)
S3_BUCKET=tt-policy-tracker-raw

# Digest
DIGEST_RECIPIENT=chip.hanna@gmail.com
DIGEST_FROM_EMAIL=policy-tracker@turbotenant.com

# AI model config
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
SUMMARIZER_MODEL=claude-sonnet-4-6

# Server — Railway sets PORT automatically
PORT=8000

# CORS — comma-separated origins (add your Vercel URL after deploying)
CORS_ORIGINS=http://localhost:3000
